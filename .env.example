# ─────────────────────────────────────────────────────────────
# Peach Studio — Vercel environment variables
#
# Copy this file to .env.local for local development.
# In Vercel: add these via Project → Settings → Environment Variables.
# NEVER commit the real .env / .env.local to the repo.
# ─────────────────────────────────────────────────────────────

# Tienda Nube API token (Settings → API → Applications → token)
TN_ACCESS_TOKEN=

# Tienda Nube Store ID (visible in the store URL or API responses)
TN_STORE_ID=
